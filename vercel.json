{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "includeFiles": "dist/public/**"
    }
  }
}
